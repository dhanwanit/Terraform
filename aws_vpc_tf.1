terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 3.0"
    }
  }
}

provider "aws" {
  region = "ap-northeast-1"
  
}

resource "aws_vpc" "terraform_vpc" {
  cidr_block = "10.0.0.0/16"

   tags = {
    Name = "Producation-vpc"
  }
}

resource "aws_subnet" "main" {
  vpc_id     = aws_vpc.terraform_vpc.id
  cidr_block = "10.0.1.0/24"

  tags = {
    Name = "Prod-subnet-1"
  }
}